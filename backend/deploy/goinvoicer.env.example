ENV=production
PORT=:4206
DB_PATH=/var/lib/goinvoicer/data/goinvoicer.db
# Keep this equal to your public app URL for same-origin deploys.
CORS_ORIGIN=https://your-app.example.com
APP_BASE_URL=https://your-app.example.com
SESSION_COOKIE_NAME=invoicer_session

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=https://your-app.example.com/api/auth/google/callback

# Stripe billing
STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key
STRIPE_SECRET_KEY=sk_live_your-secret-key
STRIPE_SINGLE_MONTHLY_PRICE_ID=price_your-live-single-monthly-price-id
STRIPE_SINGLE_YEARLY_PRICE_ID=price_your-live-single-yearly-price-id
STRIPE_TEAM_MONTHLY_PRICE_ID=price_your-live-team-monthly-price-id
STRIPE_TEAM_YEARLY_PRICE_ID=price_your-live-team-yearly-price-id
STRIPE_TRIAL_DAYS=7
STRIPE_WEBHOOK_SECRET=whsec_your-live-webhook-secret
# One-way HMAC secret for promo anti-abuse fingerprints.
# Keep this stable once live. Changing it means old promo-use fingerprints no longer match new checks.
ACCESS_LEDGER_SECRET=replace-with-a-long-random-secret
# Extra days to keep the promo anti-abuse fingerprint after the promo itself ends.
# Example: 14-day promo + 180 retention keeps the claim for 194 days from redemption.
PROMO_REDEMPTION_RETENTION_DAYS=180
