ENV=dev
PORT=:4206
DB_PATH=./data/goinvoicer.db
CORS_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:5173
SESSION_COOKIE_NAME=invoicer_session

# Google OAuth
# The callback URI must also be registered in Google Cloud Console.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:4206/api/auth/google/callback

# Stripe billing
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_SINGLE_MONTHLY_PRICE_ID=price_your-single-monthly-price-id
STRIPE_SINGLE_YEARLY_PRICE_ID=price_your-single-yearly-price-id
STRIPE_TEAM_MONTHLY_PRICE_ID=price_your-team-monthly-price-id
STRIPE_TEAM_YEARLY_PRICE_ID=price_your-team-yearly-price-id
STRIPE_TRIAL_DAYS=7
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

#Platform Admin credentials
PLATFORM_ADMIN_EMAIL=example@gmail.com
# One-way HMAC secret for promo anti-abuse fingerprints.
# Keep this stable once live. Changing it means old promo-use fingerprints no longer match new checks.
ACCESS_LEDGER_SECRET=replace-with-a-long-random-secret
# Extra days to keep the promo anti-abuse fingerprint after the promo itself ends.
# Example: 14-day promo + 180 retention keeps the claim for 194 days from redemption.
PROMO_REDEMPTION_RETENTION_DAYS=180
